{
  "name": "@proappstore/sdk",
  "version": "1.3.0",
  "description": "Browser SDK for paid apps on proappstore.online — subscriptions, license keys, premium modules.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "import": "./dist/shell.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proappstore-online/platform.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@freeappstore/sdk": "^0.6.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "sideEffects": false
}
